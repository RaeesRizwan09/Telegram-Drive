{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions",
  "windows": ["main"],
  "permissions": [
    "core:window:allow-start-dragging",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "shell:allow-open",
    "http:default",
    "dialog:default",
    "store:default",
    "core:default",
    "fs:allow-appcache-write",
    "fs:allow-appcache-read"
  ]
}